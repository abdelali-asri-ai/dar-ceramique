# -------------------------------------------------------------------
# Zelij · variables d'environnement
# Copiez ce fichier en .env.local et remplissez les clés ci-dessous.
# Sans ces clés, le site fonctionne en MODE DÉMO (paiement simulé,
# email loggué en console) — aucun code à modifier.
# -------------------------------------------------------------------

# URL publique utilisée pour les redirections Stripe (success/cancel).
# En dev : http://localhost:3000
# En prod : https://zelij.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------- Stripe --------
# Créez un compte sur https://dashboard.stripe.com/register
# Mode test : Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — généré par `stripe listen --forward-to localhost:3000/api/webhook`
# en dev, ou créé dans Dashboard → Developers → Webhooks en prod.
STRIPE_WEBHOOK_SECRET=whsec_...

# -------- Emails transactionnels --------
# https://resend.com/api-keys
RESEND_API_KEY=re_...

# Expéditeur vérifié dans Resend (doit correspondre à un domaine validé,
# ou à `onboarding@resend.dev` en mode test).
EMAIL_FROM="Zelij Atelier <atelier@zelij.com>"

# Destinataire des notifications "nouvelle commande"
EMAIL_TO=abdelali.asri.tr@gmail.com
